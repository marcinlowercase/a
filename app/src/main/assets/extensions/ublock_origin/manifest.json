{
  "manifest_version": 2,
  "name": "uBlock Origin",
  "version": "1.68.0",
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      },
      "id": "uBlock0@raymondhill.net",
      "strict_min_version": "92.0"
    },
    "gecko_android": {
      "strict_min_version": "92.0"
    }
  },
  "permissions": [
    "alarms",
    "dns",
    "menus",
    "privacy",
    "storage",
    "tabs",
    "unlimitedStorage",
    "webNavigation",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  }
}