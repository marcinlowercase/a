{
  "manifest_version": 2,
  "name": "Browser Core Extension",
  "version": "1.0",
  "description": "Handles Favicons and OutSync Protocol",
  "browser_specific_settings": {
    "gecko": {
      "id": "browser_core_extension@marcinlowercase",
      "strict_min_version": "57.0"
    }
  },
  "permissions": [
    "<all_urls>",
    "nativeMessaging",
    "nativeMessagingFromContent",
    "geckoViewAddons"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js":["theme_injector.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["<all_urls>"],
      "js": ["favicon_fetcher.js"],
      "run_at": "document_idle"
    }
  ]
}